# EIF self-hosted configuration. Copy to .env and fill in. Never commit .env.

# Runtime mode: development | production. production enforces auth on the HTTP server.
EIF_ENV=development

# Optional. Single API key for self-hosted HTTP server auth. Leave unset for local dev without auth.
EIF_API_KEY=

# Optional. Enables the LLM critic tournament (CHALLENGE) and the causal evidence probe. The core engine never calls an LLM.
OPENAI_API_KEY=
